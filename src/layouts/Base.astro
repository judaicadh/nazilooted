---
import '../styles/global.css';
import { urls } from '../data/looted';

export interface Props {
  title: string;
  crumb: string;
  active?: 'markings' | 'cases' | 'register' | 'sources' | 'about' | null;
}

const { title, crumb, active = null } = Astro.props;

const nav = (isActive: boolean) =>
  `appearance:none;background:none;border:none;padding:0 0 3px;cursor:pointer;font:${isActive ? 500 : 400} 12.5px/1 var(--sans);color:${isActive ? 'var(--ink)' : 'var(--mut)'};border-bottom:2px solid ${isActive ? 'var(--ac)' : 'transparent'}`;

const items: { label: string; href: string; key: NonNullable<Props['active']> }[] = [
  { label: 'Identify a book', href: urls.markings, key: 'markings' },
  { label: 'How they were found', href: urls.cases, key: 'cases' },
  { label: 'Browse the books', href: urls.register, key: 'register' },
  { label: 'Sources & lists', href: urls.sources, key: 'sources' },
];

const aboutLinks = [
  { label: 'Scope', href: urls.about },
  { label: 'The method', href: urls.method },
  { label: 'The five steps', href: urls.steps },
  { label: 'What we cannot account for', href: urls.gaps },
  { label: 'Where to look', href: urls.anatomy },
];
const aboutActive = active === 'about';
const dropItem = 'display:block;padding:8px 12px;border-radius:5px;font:400 13px/1.35 var(--sans);color:var(--ink);text-decoration:none;white-space:nowrap';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400&family=Oswald:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div style="min-height:100vh;background:var(--pp)">
      <header style="position:sticky;top:0;z-index:20;background:rgba(var(--pprgb),.94);backdrop-filter:blur(6px);border-bottom:1px solid rgba(var(--inkrgb),.14)">
        <div style="max-width:1180px;margin:0 auto;padding:15px 40px;display:flex;justify-content:space-between;align-items:baseline;gap:24px">
          <a href={urls.home} style="text-decoration:none;display:flex;flex-direction:column;align-items:flex-start;gap:3px">
            <span style="font:600 18px/1 var(--display);letter-spacing:.055em;text-transform:uppercase;color:var(--ink)">Nazi Looted Books</span>
            <span style="font:400 10px/1 'IBM Plex Mono',monospace;letter-spacing:.14em;text-transform:uppercase;color:var(--mut)">at Penn Libraries</span>
          </a>
          <nav style="display:flex;flex-wrap:wrap;align-items:baseline;gap:12px 22px">
            {items.map((it) => (
              <a href={it.href} style={nav(active === it.key)}>{it.label}</a>
            ))}
            <details class="about-menu" style="position:relative">
              <summary style={`${nav(aboutActive)};cursor:pointer;list-style:none`}>About ▾</summary>
              <div style="position:absolute;right:0;top:calc(100% + 10px);min-width:230px;background:var(--pp);border:1px solid rgba(var(--inkrgb),.18);border-radius:7px;box-shadow:0 8px 24px rgba(var(--inkrgb),.16);padding:6px;z-index:40;display:flex;flex-direction:column;gap:1px">
                {aboutLinks.map((l) => (<a href={l.href} style={dropItem}>{l.label}</a>))}
              </div>
            </details>
          </nav>
        </div>
      </header>

      <div style="max-width:1180px;margin:0 auto;padding:8px 40px 0">
        <div style="font:400 11px/1 'IBM Plex Mono',monospace;color:var(--fn)">{crumb}</div>
      </div>

      <main style="max-width:1180px;margin:0 auto;padding:26px 40px 90px">
        <slot />
      </main>

      <footer style="border-top:1px solid rgba(var(--inkrgb),.14);background:var(--sf2)">
        <div style="max-width:1180px;margin:0 auto;padding:22px 40px;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;font:400 11.5px/1.5 'IBM Plex Mono',monospace;color:var(--fn)">
          <span>Provenance research &amp; text: Bruce Nielsen · Penn Libraries, Katz Center for Advanced Judaic Studies</span>
          <span>Uncertainty in this record is shown, not hidden.</span>
        </div>
      </footer>
    </div>
    <script is:inline>
      document.addEventListener('click', (e) => {
        document.querySelectorAll('details.about-menu[open]').forEach((d) => {
          if (!d.contains(e.target)) d.removeAttribute('open');
        });
      });
    </script>
  </body>
</html>
