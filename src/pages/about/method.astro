---
import Base from '../../layouts/Base.astro';
import AboutNav from '../../components/AboutNav.astro';
import { urls } from '../../data/looted';
---
<Base title="The method — Nazi Looted Books" crumb="/about/method/" active="about">
  <div style="max-width:680px">
    <AboutNav active="method" />
    <h1 style="margin:0;font:400 33px/1.05 var(--display);text-transform:uppercase;letter-spacing:.02em">The method</h1>
    <p style="margin:20px 0 0;font:400 18px/1.6 var(--serif);color:var(--ink)">The identification did not begin with a database. It began with shelves, read one binding at a time, over fifteen years. What follows separates the two ways that work is told: as a manual you can act on, and as the stories where it was learned.</p>

    <div style="margin-top:30px;display:grid;gap:16px">
      <a href={urls.steps} style="text-decoration:none;display:block;padding:20px 22px;background:var(--sf);border:1px solid rgba(var(--inkrgb),.14);border-radius:4px">
        <div style="font:500 16px/1.3 var(--sans);color:var(--ink)">How to find a looted book →</div>
        <div style="margin-top:5px;font:400 14.5px/1.5 var(--serif);color:var(--mut)">Five steps, drawn from the essay and distilled into a working manual.</div>
      </a>
      <a href={urls.cases} style="text-decoration:none;display:block;padding:20px 22px;background:var(--sf);border:1px solid rgba(var(--inkrgb),.14);border-radius:4px">
        <div style="font:500 16px/1.3 var(--sans);color:var(--ink)">The stories →</div>
        <div style="margin-top:5px;font:400 14.5px/1.5 var(--serif);color:var(--mut)">The full account, with the false starts — how the method was learned in practice.</div>
      </a>
    </div>
  </div>
</Base>
