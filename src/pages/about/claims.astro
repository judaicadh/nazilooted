---
import Base from '../../layouts/Base.astro';
import AboutNav from '../../components/AboutNav.astro';
import { urls } from '../../data/looted';
---
<Base title="Restitution & claims — Nazi Looted Books" crumb="/about/claims/" active="about">
  <div style="max-width:680px">
    <AboutNav active="claims" />
    <h1 style="margin:0;font:400 33px/1.05 var(--display);text-transform:uppercase;letter-spacing:.02em">Restitution &amp; claims</h1>
    <p style="margin:20px 0 0;font:400 18px/1.6 var(--serif);color:var(--ink)">The Penn Libraries hold these books in trust, not by right. Where a rightful owner or heir can be identified, we will work toward return or a mutually agreed arrangement.</p>

    <div style="margin-top:30px;padding:22px 24px;background:var(--sf);border:1px solid rgba(var(--inkrgb),.14);border-radius:4px">
      <div style="font:500 12px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--mut)">Contact</div>
      <div style="margin-top:10px;font:400 16px/1.5 var(--serif);color:var(--ink)">Provenance Research, Kislak Center for Special Collections<br>Van Pelt–Dietrich Library, University of Pennsylvania</div>
      <div style="margin-top:8px;font:400 13.5px/1.6 'IBM Plex Mono',monospace;color:var(--ac)">provenance-books@library.upenn.edu</div>
    </div>

    <p style="margin:22px 0 0;font:400 14.5px/1.6 var(--serif);color:var(--mut)">A claim need not be complete to be worth making. If you recognise a stamp, an inscription, or a name from the <a href={urls.register}>register</a>, write to us with whatever you have.</p>
  </div>
</Base>
