---
import Base from '../../layouts/Base.astro';
import SearchNav from '../../components/SearchNav.astro';
import essay from '../../data/essay.json';

type Item = { t: string; html: string };
const items = essay as Item[];
const title = items.find((i) => i.t === 'title')?.html ?? 'The full essay';
const byline = items.find((i) => i.t === 'byline')?.html ?? '';
const body = items.filter((i) => i.t !== 'title' && i.t !== 'byline');
---
<Base title="The full essay — Bruce Nielsen" crumb="/stories/essay/" active="stories">
  <div style="max-width:720px">
    <SearchNav active="essay" />

    <div style="font:400 11px/1 'IBM Plex Mono',monospace;letter-spacing:.06em;text-transform:uppercase;color:var(--fn)">The complete essay, in the author’s words</div>
    <h1 style="margin:12px 0 0;font:400 30px/1.25 var(--serif);letter-spacing:-.01em" set:html={title}></h1>
    <div style="margin-top:12px;font:500 12.5px/1.5 'IBM Plex Mono',monospace;color:var(--mut)" set:html={byline}></div>
    <div style="margin-top:6px;font:400 12.5px/1.5 'IBM Plex Mono',monospace;color:var(--fn)">University of Pennsylvania Libraries · Katz Center for Advanced Judaic Studies</div>

    <div style="margin-top:8px">
      {body.map((it) => (
        it.t === 'hr'
          ? (<div style="height:1px;background:rgba(var(--inkrgb),.14);margin:30px 0"></div>)
          : it.t === 'step'
            ? (<p style="margin:18px 0 0;padding-left:16px;border-left:2px solid rgba(var(--inkrgb),.2);font:400 16px/1.7 var(--serif);color:var(--ink);text-wrap:pretty" set:html={it.html}></p>)
            : (<p style="margin:18px 0 0;font:400 16px/1.7 var(--serif);color:var(--ink);text-wrap:pretty" set:html={it.html}></p>)
      ))}
    </div>
  </div>
</Base>
