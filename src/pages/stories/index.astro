---
import Base from '../../layouts/Base.astro';
import { urls, CASES } from '../../data/looted';
---
<Base title="How these books were found — Nazi Looted Books" crumb="/stories/" active="stories">
  <div style="max-width:760px">
    <h1 style="margin:14px 0 0;font:400 33px/1.05 var(--display);text-transform:uppercase;letter-spacing:.02em">How these books were found</h1>
    <p style="margin:16px 0 0;font:400 16.5px/1.55 var(--serif);color:var(--mut)">The identification did not come from a database query. It came from reading shelves, one binding at a time. These are the books whose discovery turned on a single mark — and what it took to find them.</p>

    <div style="margin-top:28px;border-top:1px solid rgba(var(--inkrgb),.14)">
      {CASES.map((c) => (
        <a href={urls.case(c.slug)} style="text-decoration:none;border-bottom:1px solid rgba(var(--inkrgb),.14);display:grid;grid-template-columns:1fr auto;gap:20px;align-items:baseline;padding:20px 4px">
          <span>
            <span style="display:block;font:500 18px/1.3 var(--serif);color:var(--ink)">{c.title}</span>
            <span style="display:block;margin-top:5px;font:400 14.5px/1.5 var(--serif);color:var(--mut)">{c.blurb}</span>
          </span>
          <span style="font:400 20px/1 var(--serif);color:var(--ac)">→</span>
        </a>
      ))}
    </div>
  </div>
</Base>
