---
import Base from '../../layouts/Base.astro';
import { urls, MARKINGS } from '../../data/looted';

export function getStaticPaths() {
  return MARKINGS.map((m) => ({ params: { slug: m.slug }, props: { marking: m } }));
}

const { marking } = Astro.props;
const hatch = 'height:180px;border:1px solid rgba(var(--inkrgb),.16);border-radius:3px;background-image:repeating-linear-gradient(-45deg,#eae5da,#eae5da 8px,#f2eee5 8px,#f2eee5 16px);display:flex;align-items:flex-end;padding:12px';
---
<Base title={`${marking.name} — Nazi Looted Books`} crumb={`/markings/${marking.slug}/`} active="markings">
  <a href={urls.markings} style="font:400 12.5px/1 var(--sans);color:var(--ac)">← All markings</a>

  <div class="col-stack" style="margin-top:16px;display:grid;grid-template-columns:1fr 320px;gap:44px;align-items:start">
    <div>
      <h1 style="margin:0;font:400 32px/1.15 var(--serif);letter-spacing:-.01em">{marking.name}</h1>
      <p style="margin:14px 0 0;max-width:560px;font:400 16.5px/1.6 var(--serif);color:var(--ink)">{marking.desc}</p>

      <div style="margin-top:26px;font:500 11px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--mut)">Examples, photographed in the book</div>
      <div style="margin-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div style={hatch}><span style="font:400 10.5px/1.5 'IBM Plex Mono',monospace;color:var(--fn3)">clean example — {marking.name}</span></div>
        <div style={hatch}><span style="font:400 10.5px/1.5 'IBM Plex Mono',monospace;color:var(--fn3)">partly obscured — {marking.obscured}</span></div>
      </div>
      <p style="margin:14px 0 0;max-width:560px;font:400 13.5px/1.55 var(--serif);font-style:italic;color:var(--mut)">{marking.note}</p>
    </div>

    <aside style="background:var(--sf);border:1px solid rgba(var(--inkrgb),.14);border-radius:4px;padding:20px 22px">
      <div style="display:flex;flex-direction:column;gap:16px">
        <div>
          <div style="font:500 10.5px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--fn)">Issuing body</div>
          <div style="margin-top:6px;font:400 14.5px/1.4 var(--serif);color:var(--ink)">{marking.bodyFull}</div>
        </div>
        <div style="height:1px;background:rgba(var(--inkrgb),.12)"></div>
        <div>
          <div style="font:500 10.5px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--fn)">Where it appears</div>
          <div style="margin-top:6px;font:400 14.5px/1.4 var(--serif);color:var(--ink)">{marking.where}</div>
          <a href={urls.anatomy} style="display:inline-block;margin-top:6px;font:400 12.5px/1 var(--sans);color:var(--ac)">See on the diagram →</a>
        </div>
        <div style="height:1px;background:rgba(var(--inkrgb),.12)"></div>
        <div>
          <div style="font:500 10.5px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--fn)">In Penn holdings</div>
          <div style="margin-top:6px;font:400 22px/1 var(--serif);color:var(--ink)">{marking.count} <span style="font-size:13px;color:var(--fn)">books</span></div>
        </div>
        <div style="height:1px;background:rgba(var(--inkrgb),.12)"></div>
        <div>
          <div style="font:500 10.5px/1 'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;color:var(--fn)">Reference</div>
          <div style="margin-top:6px;font:400 13.5px/1.45 var(--serif);color:var(--ink)">{marking.bencowitz}</div>
        </div>
        <a href={`${urls.register}?mark=${marking.slug}`} style="text-align:center;text-decoration:none;background:var(--ink);color:var(--pp);border-radius:3px;padding:11px 14px;font:500 12.5px/1 var(--sans)">Books carrying this marking →</a>
      </div>
    </aside>
  </div>
</Base>
